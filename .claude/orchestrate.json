{
  "host": "github",
  "languages": ["python"],
  "mode": "fleet",
  "issueLimit": 50,
  "roster": ["APPLE", "BANANA", "CHERRY", "DRAGONFRUIT", "ELDERBERRY", "FIG", "GRAPE", "HONEYDEW", "INCABERRY", "JACKFRUIT", "KIWI"],
  "worktreeBranchPattern": "^(?<agent>[a-z]+)/issue-(?<issue>\\d+)",
  "defaultBase": "origin/main",
  "paths": { "worktreeDir": ".claude/worktrees" },
  "pmtools": { "home": null, "port": "py" },
  "close": {
    "verify": {
      "comment": "Close-time gate mirrors CI (.github/workflows/ci.yml): the zero-dep unit runner + the W3C conformance floor. Unlike pycats' ruff gate, this repo's runners are ZERO-DEPENDENCY (system python3, no venv), so cwd=worktree runs them directly against the code being merged — no git-common-dir venv resolution needed.",
      "commands": [
        "python3 run_tests.py",
        "python3 tests/w3c/runner.py --min 150"
      ],
      "cwd": "worktree",
      "enabled": true
    }
  },
  "enrichment": {
    "statusCommand": "pmtools status",
    "claimCommand": "pmtools claim",
    "preflightCommand": "pmtools preflight",
    "closeCommand": "pmtools close"
  },
  "advisory": {
    "iceSource": "stats/ice-scores.csv",
    "clusterFile": null,
    "sequencingDocRef": null
  },
  "storage": {
    "dbPath": null,
    "velocity": { "enabled": false, "csvMirror": null, "logCommand": "pmtools velocity log" },
    "errors": { "enabled": true, "csvMirror": null, "logCommand": "pmtools error log" }
  },
  "claims": {
    "enabled": true,
    "dir": "claims-data",
    "prefix": "SCP",
    "agentScoped": null,
    "evidenceDir": "claims-data/evidence",
    "overloadedTerms": ["claim", "tick", "store", "atomic", "recover", "defer", "poison", "backoff", "session"]
  }
}
